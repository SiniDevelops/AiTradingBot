# ==========================================
# AiTradingBot Environment Configuration
# ==========================================

# --- Zerodha Kite Configuration ---
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
KITE_REQUEST_TOKEN=your_kite_request_token_here

# --- General System Settings ---
# Mode options: paper, live
TRADING_MODE=paper

# --- AI & News APIs ---
GNEWS_API_KEY=your_gnews_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# --- Scheduler Intervals (Optional) ---
# NEWS_INTERVAL_SECONDS=300
# MARKET_INTERVAL_SECONDS=60

# --- Database Integration (Optional) ---
# MONGODB_URI=mongodb://localhost:27017/trading_bot

# --- Telegram Alerts (Optional) ---
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# --- Risk Management (Optional overrides) ---
# MAX_CAPITAL_PER_TRADE=10000
# DAILY_LOSS_LIMIT=3000
